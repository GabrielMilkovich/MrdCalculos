# MRD CALC — Environment Variables
# Copy this file to .env and fill in your Supabase credentials.
# NEVER commit .env to version control.

# Supabase (required)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# OpenAI API Key (required for Edge Functions: extraction, embeddings, AI audit)
# Set this in Supabase Dashboard > Project Settings > Edge Functions > Secrets
# as OPENAI_API_KEY
# OPENAI_API_KEY=sk-...

# Mistral API Key (required for OCR via ocr-document / process-document-mistral)
# https://console.mistral.ai/api-keys
# Set this in Supabase Dashboard > Project Settings > Edge Functions > Secrets
# as MISTRAL_API_KEY
# MISTRAL_API_KEY=...

# ─────────────────────────────────────────────────────────────────────────
# Port PJe-Calc — Feature flags (Fase 0)
# ─────────────────────────────────────────────────────────────────────────
# Ativa módulos portados do PJe-Calc v2.15.1 Java para TypeScript.
# Default = off (todos os módulos rodando o engine atual).
# Ver: docs/PORT-PJECALC-PLAN.md §6.1
# Valores aceitos: true, 1, on, yes (case-insensitive)
# Todas as flags são removidas ao final da Fase 9.

# VITE_USE_PORTED_IRPF=false
# VITE_USE_PORTED_INSS=false
# VITE_USE_PORTED_FGTS=false
# VITE_USE_PORTED_CARTAO=false
# VITE_USE_PORTED_ATUALIZACAO=false
# VITE_USE_PORTED_PAGAMENTO=false
# VITE_USE_PORTED_CALCULO=false
# VITE_USE_PORTED_VERBA=false
# VITE_USE_PORTED_HONORARIO=false
# VITE_USE_PORTED_CUSTAS=false
# VITE_USE_PORTED_FERIAS=false
# VITE_USE_PORTED_MULTA=false
# VITE_USE_PORTED_SALARIO_FAMILIA=false
# VITE_USE_PORTED_SEGURO_DESEMPREGO=false
# VITE_USE_PORTED_PENSAO_ALIMENTICIA=false
# VITE_USE_PORTED_PREVIDENCIA_PRIVADA=false
