# MRD CALC — Environment Variables
# Copy this file to .env and fill in your Supabase credentials.
# NEVER commit .env to version control.

# Supabase (required)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# OpenAI API Key (required for Edge Functions: OCR, extraction, embeddings, AI audit)
# Set this in Supabase Dashboard > Project Settings > Edge Functions > Secrets
# as OPENAI_API_KEY
# OPENAI_API_KEY=sk-...
